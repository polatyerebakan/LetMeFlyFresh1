# Unreal Engine Git LFS - Maksimum Kapsamlı Şablon

# Varsayılan satır sonu ayarları
* text=auto
# Kaynak Kod Dosyaları
*.cs text diff=csharp
*.cpp text diff=cpp
*.h text diff=cpp
*.inline text diff=cpp
*.hlsl text
*.glsl text
*.uproject text
# Unreal Temel Assetleri ve Haritalar
*.uasset filter=lfs diff=lfs merge=lfs -text
