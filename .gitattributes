#-------------------------------------------------------------------------------
# Unreal Engine Git LFS ve Dosya Yapılandırması

# Varsayılan satır sonu ayarları (Kaynak kodlar için)
* text=auto
# Kaynak Kod Dosyaları (Git'in satır sonlarını düzgün işlemesi için)
*.cs text diff=csharp
*.cpp text diff=cpp
*.h text diff=cpp
*.inline text diff=cpp
*.hlsl text
*.glsl text
*.uproject text
# Git LFS - Büyük ve Binary Dosyalar (Unreal Engine Asset'leri)
# Unreal İçerik ve Harita Dosyaları (Kritik Assetler)
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
# 3D Modeller ve Animasyonlar
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.max filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.abc filter=lfs diff=lfs merge=lfs -text
# Dokular, Görseller ve UI Elementleri
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text
*.hdr filter=lfs diff=lfs merge=lfs -text
*.tif filter=lfs diff=lfs merge=lfs -text
*.tiff filter=lfs diff=lfs merge=lfs -text
*.bmp filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
# Ses Dosyaları
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.cue filter=lfs diff=lfs merge=lfs -text
# Yazı Tipleri (Fonts)
*.ttf filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text
# Derlenmiş Binary Dosyalar, Kütüphaneler ve Debug Sembolleri (Büyük Boyutlular)
*.dll filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
*.pdb filter=lfs diff=lfs merge=lfs -text
*.lib filter=lfs diff=lfs merge=lfs -text
*.a filter=lfs diff=lfs merge=lfs -text
*.so filter=lfs diff=lfs merge=lfs -text
*.dylib filter=lfs diff=lfs merge=lfs -text
# Diğer Büyük Medya ve Video Formatları
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.mkv filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
# Unreal Engine İçi Diğer Binary ve Önbellek Formatları
*.upack filter=lfs diff=lfs merge=lfs -text
*.uplugin filter=lfs diff=lfs merge=lfs -text
*.udk filter=lfs diff=lfs merge=lfs -text
# Unreal Diff/Merge Ayarları (Görsel Karşılaştırma Desteği)
# Unreal'ın kendi diff aracıyla çakışmaları (conflict) inceleyebilmek için
*.uasset diff=passthrough
*.umap diff=passthrough
